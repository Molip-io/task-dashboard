# Required: Bearer token for POST /api/work-status-summaries
DASHBOARD_API_TOKEN=your-secret-token-here

# Optional: Supabase (omit to use in-memory store for local dev)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: Notion (primary data source)
# If set, GET /api/work-status-summaries/latest reads from Notion first.
# Fallback to Supabase if not set or if Notion query fails.
NOTION_TOKEN=secret_xxx
NOTION_WORK_STATUS_SUMMARY_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
